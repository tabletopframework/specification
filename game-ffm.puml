@startuml player-with-axes
!include lib/game.puml!core
!include lib/i18n.puml!en
skinparam ranksep 20
skinparam nodesep 1

<style>
  .axis {
    FontColor: black;
    FontSize: 30;
  }
</style>

$iconify_players()

$fill_axes()
$empty_axes()
$join_axes_3x3(hidden, hidden)
@enduml

@startuml axis-x-relation
!include lib/game.puml!core
!include lib/i18n.puml!en
skinparam ranksep 20
skinparam nodesep 20
allowmixing

diamond relation
note top: $translate(specification)

rectangle "$translate(xAxisNegativeTerm)" as left
' note left: $translate(declaration)
note left: $translate(abstract)
rectangle "$translate(xAxisPositiveTerm)" as right
' note right: $translate(detalization)
note right: $translate(concrete)

left -- relation
relation -- right
@enduml

@startuml axis-y-relation
!include lib/game.puml!core
!include lib/i18n.puml!en
skinparam ranksep 20
skinparam nodesep 20
allowmixing

diamond relation
note top: $translate(consequence)

rectangle "$translate(yAxisPositiveTerm)" as left
note left: $translate(structure)
rectangle "$translate(yAxisNegativeTerm)" as right
note right: $translate(algorithm)

left -- relation
relation -- right
@enduml

@startuml matrix-with-axes
!include lib/game.puml!core
!include lib/i18n.puml!en
skinparam ranksep 40
skinparam nodesep 1

<style>
  label {
    FontSize: 30;
  }
</style>

$iconify_players()

$fill_axes()
$empty_axes()
$join_axes_3x3(hidden, hidden)

$fill_matrix(1)
$join_matrix_3x3()
@enduml

@startuml matrix-with-protocols-singular
!include lib/game.puml!core
!include lib/i18n.puml!en
skinparam ranksep 20
skinparam nodesep 40

<style>
  .matrix {
    FontSize: 30;
    FontColor: Grey;
  }
</style>

$iconify_players()

$fill_grid_3x3(1)

$empty_axes()
$join_axes_3x3()

$fill_matrix(1)
$join_matrix_3x3()
@enduml

@startuml matrix-with-protocols-plural
